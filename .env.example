OPENROUTER_API_KEY=your-api-key

# Optional. Defaults to openai/gpt-5-mini. Any model ID OpenRouter accepts
# (e.g. anthropic/claude-sonnet-4, mistralai/mistral-large, openai/gpt-4o-mini).
# In prod swap for EU-hosted (e.g. "mistralai/mistral-large-latest") per ADR 0001.
# ANSWER_AGENT_MODEL=openai/gpt-5-mini

# Optional. Defaults to https://openrouter.ai/api/v1.
# OPENROUTER_URL=https://openrouter.ai/api/v1

# Optional. Defaults to http://localhost:11434/v1 (matches the Docker Compose Ollama service).
# Override when Ollama is reachable elsewhere.
# OLLAMA_URL=http://localhost:11434/v1

# Optional. Defaults to file:./chunks.db (LibSQL embedded file).
# CHUNKS_DB_URL=file:./chunks.db
